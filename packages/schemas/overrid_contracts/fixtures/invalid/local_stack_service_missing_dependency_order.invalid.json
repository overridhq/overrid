{
  "schema_version": "local-development-stack.v0.1",
  "service_definition": {
    "service_id": "service:api",
    "service_kind": "api",
    "command": [
      "cargo",
      "run"
    ],
    "working_directory": "repo://.",
    "env_refs": [],
    "dependency_order": 0,
    "depends_on": [],
    "health_check": {
      "kind": "http",
      "endpoint": "http://127.0.0.1:18080/healthz",
      "expected_state": "ready",
      "timeout_ms": 60000
    },
    "shutdown_behavior": "graceful_then_kill",
    "log_target": "log://local_stack/api.log",
    "restart_class": "required",
    "local_only": true,
    "test_only": true
  }
}
