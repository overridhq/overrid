{
  "schema_family": "shared-schema-package",
  "schema_version": "shared-schema-package.v0.1",
  "phase3_contract_modules": {
    "manifest_registry_modules": [
      {
        "module_name": "workload_manifest",
        "module_family": "manifest_registry",
        "schema_version": "shared-schema-package.v0.1",
        "owning_service_family": "SDS #24 Overpack",
        "downstream_consumers": [
          "Overpack"
        ],
        "source_of_truth": "json_schema",
        "rust_projection_non_authoritative": true,
        "runtime_authority": "owning_service",
        "privacy_class": "tenant_private",
        "strict_unknown_field_rejection": true,
        "raw_secret_values_allowed": false,
        "private_key_material_allowed": false,
        "tenant_actor_refs_required": true,
        "append_only_record": false,
        "reason_code_required": false,
        "correction_shape_required": false,
        "privacy_class_required": true,
        "typed_secret_refs_required": true,
        "untyped_capability_blobs_allowed": true,
        "required_refs": [
          "workload_ref",
          "tenant_ref",
          "actor_ref",
          "package_ref",
          "policy_ref"
        ],
        "required_fields": [
          "schema_version",
          "resource_requirements",
          "data_refs",
          "network_intent",
          "retry_policy"
        ],
        "validation_rules": [
          {
            "rule_id": "workload_manifest.requires_typed_secret_refs",
            "reason_code": "manifest.secret_ref_required",
            "correction_fields": [
              "secret_ref",
              "schema_version"
            ],
            "enforcement": "require_typed_ref"
          }
        ]
      }
    ]
  }
}
