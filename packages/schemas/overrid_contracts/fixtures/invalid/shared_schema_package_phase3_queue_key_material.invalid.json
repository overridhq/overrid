{
  "schema_family": "shared-schema-package",
  "schema_version": "shared-schema-package.v0.1",
  "phase3_contract_modules": {
    "queue_lease_credential_key_modules": [
      {
        "module_name": "credential_key_metadata",
        "module_family": "queue_lease_credential_key",
        "schema_version": "shared-schema-package.v0.1",
        "owning_service_family": "SDS #9 Overkey",
        "downstream_consumers": [
          "Overkey"
        ],
        "source_of_truth": "json_schema",
        "rust_projection_non_authoritative": true,
        "runtime_authority": "owning_service",
        "privacy_class": "encrypted_private",
        "strict_unknown_field_rejection": true,
        "raw_secret_values_allowed": false,
        "private_key_material_allowed": true,
        "tenant_actor_refs_required": true,
        "append_only_record": true,
        "reason_code_required": true,
        "correction_shape_required": true,
        "privacy_class_required": true,
        "typed_secret_refs_required": true,
        "untyped_capability_blobs_allowed": false,
        "required_refs": [
          "credential_ref",
          "signer_ref",
          "key_ref",
          "tenant_ref",
          "actor_ref",
          "audit_ref"
        ],
        "required_fields": [
          "credential_metadata",
          "key_rotation",
          "revocation",
          "reason_code",
          "trace_id"
        ],
        "validation_rules": [
          {
            "rule_id": "credential_key_metadata_refs_only",
            "reason_code": "credential.private_key_material_rejected",
            "correction_fields": [
              "credential_ref",
              "signer_ref",
              "secret_ref"
            ],
            "enforcement": "reject"
          }
        ]
      }
    ]
  }
}
