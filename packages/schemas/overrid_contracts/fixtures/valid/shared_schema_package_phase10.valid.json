{
  "schema_family": "shared-schema-package",
  "schema_version": "shared-schema-package.v0.1",
  "phase10_validation_handoff_contract": {
    "structure_checks": [
      "title_prefix",
      "attached_sds_link",
      "phase_headings_1_through_10",
      "work_item_design_output_validation_fields",
      "exit_gate_present",
      "local_markdown_links"
    ],
    "tech_stack_alignment_checks": [
      "canonical_json_schema_authority",
      "rust_first_generation",
      "typescript_web_second",
      "protobuf_internal_only",
      "strict_sensitive_validation",
      "no_conventional_cloud_product_boundary"
    ],
    "master_plan_alignment_checks": [
      "phase_0_through_13_order_unchanged",
      "sds7_phase0_foundation_package",
      "downstream_expansion_owner_gated",
      "master_crosswalk_link_preserved"
    ],
    "source_alignment_documents": [
      "docs/sds/foundation/shared_schema_package.md",
      "docs/service_catalog/foundation/shared_schema_package.md",
      "docs/build_plan/sub_build_plan_007_shared_schema_package.md",
      "docs/build_plan/master_plan.md",
      "docs/build_plan/service_catalog_alignment.md",
      "docs/overrid_tech_stack_choice.md",
      "docs/planning/shared_schema_package_phase_10_plan.md",
      "docs/planning/shared_schema_package_phase_10_progress.md"
    ],
    "downstream_handoff_rules": [
      { "consumer_family": "control_plane_services", "owning_service_authority_retained": true, "schema_request_path": "owner-gated schema request through control-plane reviewers", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "execution_services", "owning_service_authority_retained": true, "schema_request_path": "owner-gated schema request through execution reviewers", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "trust_policy_services", "owning_service_authority_retained": true, "schema_request_path": "owner-gated schema request through trust-policy reviewers", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "accounting_services", "owning_service_authority_retained": true, "schema_request_path": "owner-gated schema request through accounting reviewers", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "data_storage_namespace_services", "owning_service_authority_retained": true, "schema_request_path": "owner-gated schema request through data/storage/namespace reviewers", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "adapters", "owning_service_authority_retained": true, "schema_request_path": "owner-gated schema request through adapter SDS reviewers", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "sdk", "owning_service_authority_retained": true, "schema_request_path": "consume generated contracts after owning schema release", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "cli", "owning_service_authority_retained": true, "schema_request_path": "consume generated contracts through SDK/Overgate envelopes only", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "admin_developer_ui", "owning_service_authority_retained": true, "schema_request_path": "consume TypeScript/web projections generated second", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "native_apps", "owning_service_authority_retained": true, "schema_request_path": "consume native-app schemas after Phase 12 owner approval", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "mobile", "owning_service_authority_retained": true, "schema_request_path": "consume mobile bindings after shared schema compatibility checks", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "ai_gateway_services", "owning_service_authority_retained": true, "schema_request_path": "consume AI schemas through owner-gated refs and privacy classes", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false },
      { "consumer_family": "docdex_rag", "owning_service_authority_retained": true, "schema_request_path": "consume encrypted Docdex RAG schemas through ref-only contracts", "generated_contract_consumption_required": true, "runtime_authority_allowed": false, "audit_finality_allowed": false, "policy_truth_allowed": false, "accounting_finality_allowed": false, "storage_truth_allowed": false, "secret_custody_allowed": false }
    ],
    "forbidden_assumption_terms": [
      "PostgreSQL",
      "Redis",
      "S3",
      "MinIO",
      "NATS",
      "Kafka",
      "Vault",
      "blockchain",
      "NFT",
      "pricing",
      "revenue",
      "customer-count"
    ],
    "source_hash_inputs": [
      "packages/schemas/overrid_contracts/v0/shared_schema_package.schema.json",
      "packages/schemas/overrid_contracts/codegen_manifest.json",
      "docs/build_plan/sub_build_plan_007_shared_schema_package.md",
      "docs/build_plan/master_plan.md",
      "docs/build_plan/service_catalog_alignment.md",
      "docs/overrid_tech_stack_choice.md"
    ],
    "rust_projection": {
      "path": "packages/schemas/overrid_contracts/src/lib.rs",
      "validator_entrypoint": "SharedSchemaPhase10ValidationHandoffContract::canonical().validate()",
      "non_authoritative": true
    }
  }
}
