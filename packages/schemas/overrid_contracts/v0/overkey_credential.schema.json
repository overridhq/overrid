{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overrid.local/schemas/overkey_credential.v0.json",
  "title": "Overkey Credential Contracts v0",
  "type": "object",
  "required": [
    "schema_family",
    "schema_version",
    "credential_record"
  ],
  "properties": {
    "schema_family": {
      "const": "overkey.credential"
    },
    "schema_version": {
      "const": "overkey.credential.v0"
    },
    "credential_record": {
      "$ref": "#/$defs/credential_record"
    }
  },
  "$defs": {
    "credential_record": {
      "type": "object",
      "required": [
        "tenant_id",
        "subject_ref",
        "credential_id",
        "key_id",
        "key_version",
        "credential_class",
        "allowed_uses",
        "status",
        "created_at",
        "not_after",
        "algorithm",
        "canonicalization",
        "audit_refs",
        "protection_class",
        "secret_ref",
        "last_used_at",
        "rotation_refs",
        "revocation_refs"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "subject_ref": {
          "type": "string",
          "minLength": 1
        },
        "credential_id": {
          "type": "string",
          "minLength": 1
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "key_version": {
          "type": "integer",
          "minimum": 1
        },
        "credential_class": {
          "enum": [
            "api_key",
            "public_signing_key",
            "service_account_key",
            "delegation"
          ]
        },
        "allowed_uses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "status": {
          "$ref": "#/$defs/credential_status"
        },
        "created_at": {
          "type": "string",
          "minLength": 1
        },
        "not_after": {
          "type": "string",
          "minLength": 1
        },
        "algorithm": {
          "type": "string",
          "minLength": 1
        },
        "canonicalization": {
          "const": "overrid.canonical_json.v0"
        },
        "audit_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "protection_class": {
          "type": "string",
          "minLength": 1
        },
        "secret_ref": {
          "$ref": "#/$defs/secret_ref"
        },
        "last_used_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "rotation_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "revocation_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "api_key_record": {
      "type": "object",
      "required": [
        "credential_id",
        "tenant_id",
        "key_version",
        "api_key_prefix",
        "api_key_hash_ref",
        "hash_algorithm",
        "allowed_uses",
        "status",
        "created_at",
        "last_used_at",
        "lookup_hint_rules",
        "raw_key_discarded",
        "audit_refs"
      ],
      "properties": {
        "api_key_hash_ref": {
          "type": "string",
          "pattern": "^hash:api_key:blake3:"
        },
        "hash_algorithm": {
          "const": "BLAKE3-keyed-lookup"
        }
      }
    },
    "public_key_record": {
      "type": "object",
      "required": [
        "credential_id",
        "tenant_id",
        "key_id",
        "key_version",
        "algorithm",
        "public_key_ref",
        "key_fingerprint_ref",
        "canonicalization",
        "allowed_signature_uses",
        "not_before",
        "not_after",
        "protection_class",
        "status",
        "audit_refs"
      ],
      "properties": {
        "algorithm": {
          "const": "Ed25519"
        },
        "canonicalization": {
          "const": "overrid.canonical_json.v0"
        }
      }
    },
    "service_account_key": {
      "type": "object",
      "required": [
        "credential_id",
        "tenant_id",
        "service_account_id",
        "key_version",
        "public_key_ref",
        "algorithm",
        "allowed_services",
        "allowed_command_classes",
        "allowed_uses",
        "protection_class",
        "signed_call_required",
        "status",
        "audit_refs"
      ]
    },
    "delegation_record": {
      "type": "object",
      "required": [
        "delegation_id",
        "tenant_id",
        "subject_ref",
        "delegated_to",
        "allowed_uses",
        "not_after",
        "status",
        "audit_refs"
      ]
    },
    "rotation_record": {
      "type": "object",
      "required": [
        "rotation_id",
        "tenant_id",
        "credential_id",
        "from_key_ref",
        "to_key_ref",
        "status",
        "audit_refs"
      ]
    },
    "revocation_record": {
      "type": "object",
      "required": [
        "revocation_id",
        "tenant_id",
        "credential_id",
        "revoked_at",
        "reason_code",
        "audit_refs"
      ]
    },
    "verification_result": {
      "type": "object",
      "required": [
        "tenant_id",
        "credential_id",
        "key_id",
        "key_version",
        "subject_ref",
        "allowed_use",
        "command_class",
        "verified",
        "verification_state",
        "verification_class",
        "reason_code",
        "algorithm",
        "canonicalization",
        "body_hash_ref",
        "request_hash_ref",
        "evidence_ref",
        "revocation_epoch",
        "cache_key_ref",
        "retryability",
        "audit_refs"
      ],
      "properties": {
        "body_hash_ref": {
          "type": "string",
          "pattern": "^hash:.*blake3:"
        },
        "request_hash_ref": {
          "type": "string",
          "pattern": "^hash:.*blake3:"
        },
        "evidence_ref": {
          "type": "string",
          "pattern": "^hash:.*blake3:"
        },
        "cache_key_ref": {
          "type": "string",
          "pattern": "^hash:.*blake3:"
        },
        "verification_state": {
          "enum": [
            "verified",
            "denied",
            "blocked"
          ]
        }
      }
    },
    "secret_ref": {
      "type": "object",
      "required": [
        "provider",
        "reference",
        "protection_class",
        "resolvable_by"
      ],
      "properties": {
        "reference": {
          "type": "string",
          "pattern": "^secret://"
        }
      }
    },
    "api_error": {
      "type": "object",
      "required": [
        "error_code",
        "message",
        "retryability",
        "field_refs"
      ]
    },
    "overwatch_event": {
      "type": "object",
      "required": [
        "event_id",
        "tenant_id",
        "event_class",
        "credential_id",
        "reason_code",
        "audit_ref"
      ]
    },
    "credential_status": {
      "enum": [
        "pending",
        "active",
        "rotating",
        "suspended",
        "revoked",
        "expired",
        "tombstoned"
      ]
    }
  }
}
