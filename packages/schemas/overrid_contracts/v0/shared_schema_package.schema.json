{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.overrid.local/overrid_contracts/v0/shared_schema_package.schema.json",
  "title": "Shared Schema Package Phase 2 Through Phase 5 Contracts",
  "description": "Canonical JSON Schema source for SUB BUILD PLAN #7 Phase 2 package layout/common primitives, Phase 3 Phase 0/1 contract modules, Phase 4 generation toolchain/projection metadata, and Phase 5 strict validation metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_family",
    "schema_version",
    "layout",
    "identifier_primitives",
    "lifecycle_primitives",
    "privacy_classes",
    "reason_code_registry"
  ],
  "properties": {
    "schema_family": {
      "const": "shared-schema-package"
    },
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "layout": {
      "$ref": "#/$defs/source_layout"
    },
    "identifier_primitives": {
      "type": "array",
      "minItems": 19,
      "items": {
        "$ref": "#/$defs/typed_ref_primitive"
      }
    },
    "lifecycle_primitives": {
      "$ref": "#/$defs/lifecycle_primitives"
    },
    "privacy_classes": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/privacy_class_rule"
      }
    },
    "reason_code_registry": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/reason_code_entry"
      }
    },
    "phase3_contract_modules": {
      "$ref": "#/$defs/phase3_contract_modules"
    },
    "phase4_generation_toolchain": {
      "$ref": "#/$defs/phase4_generation_toolchain"
    },
    "phase5_validation_contract": {
      "$ref": "#/$defs/phase5_validation_contract"
    }
  },
  "$defs": {
    "schema_version": {
      "const": "shared-schema-package.v0.1"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_prefix": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:"
    },
    "reason_code": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"
    },
    "privacy_class": {
      "enum": [
        "public",
        "tenant_private",
        "regulated",
        "encrypted_private",
        "user_content",
        "system_service_only",
        "redacted_diagnostic"
      ]
    },
    "source_layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved_source_roots",
        "generated_output_roots",
        "fixture_roots",
        "compatibility_report_roots",
        "internal_binary_projection_roots",
        "generated_in_source_directories"
      ],
      "properties": {
        "approved_source_roots": {
          "type": "array",
          "minItems": 4,
          "items": {
            "enum": [
              "packages/schemas/README.md",
              "packages/schemas/overrid_contracts/v0",
              "packages/schemas/overrid_contracts/codegen_manifest.json",
              "packages/schemas/overrid_contracts/README.md"
            ]
          }
        },
        "generated_output_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "packages/schemas/overrid_contracts/src/lib.rs",
              "packages/schemas/overrid_contracts/generated/docs",
              "packages/schemas/admin_ui/generated"
            ]
          }
        },
        "fixture_roots": {
          "type": "array",
          "minItems": 2,
          "items": {
            "enum": [
              "packages/schemas/overrid_contracts/fixtures/valid",
              "packages/schemas/overrid_contracts/fixtures/invalid"
            ]
          }
        },
        "compatibility_report_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "packages/schemas/overrid_contracts/compatibility",
              "docs/specs/generated"
            ]
          }
        },
        "internal_binary_projection_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "packages/schemas/overrid_contracts/protobuf/internal"
            ]
          }
        },
        "generated_in_source_directories": {
          "const": false
        }
      }
    },
    "typed_ref_primitive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primitive_name",
        "object_family",
        "ref_prefix",
        "privacy_class",
        "public_object_required",
        "unstructured_string_allowed",
        "versioned_when_external",
        "examples"
      ],
      "properties": {
        "primitive_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "object_family": {
          "enum": [
            "person",
            "organization",
            "tenant",
            "node",
            "app",
            "native_service",
            "service_account",
            "system_service",
            "central_ai_actor",
            "overasset",
            "namespace",
            "route",
            "package",
            "workload",
            "queue",
            "lease",
            "receipt",
            "evidence",
            "secret_reference"
          ]
        },
        "ref_prefix": {
          "$ref": "#/$defs/ref_prefix"
        },
        "privacy_class": {
          "$ref": "#/$defs/privacy_class"
        },
        "public_object_required": {
          "type": "boolean"
        },
        "unstructured_string_allowed": {
          "const": false
        },
        "versioned_when_external": {
          "type": "boolean"
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "lifecycle_primitives": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "logical_sequence",
        "schema_version",
        "command_id",
        "trace_id",
        "idempotency_key",
        "request_hash",
        "payload_hash",
        "compatibility_window",
        "deprecation_metadata"
      ],
      "properties": {
        "timestamp": {
          "$ref": "#/$defs/non_empty_string"
        },
        "logical_sequence": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "command_id": {
          "$ref": "#/$defs/ref_prefix"
        },
        "trace_id": {
          "const": "trace_"
        },
        "idempotency_key": {
          "const": "idem_"
        },
        "request_hash": {
          "const": "hash_"
        },
        "payload_hash": {
          "const": "hash_"
        },
        "compatibility_window": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "current_major",
            "previous_major_supported"
          ],
          "properties": {
            "current_major": {
              "type": "integer",
              "minimum": 0
            },
            "previous_major_supported": {
              "const": true
            }
          }
        },
        "deprecation_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "deprecated_since",
            "retirement_after",
            "migration_plan_ref"
          ],
          "properties": {
            "deprecated_since": {
              "$ref": "#/$defs/non_empty_string"
            },
            "retirement_after": {
              "$ref": "#/$defs/non_empty_string"
            },
            "migration_plan_ref": {
              "$ref": "#/$defs/ref_prefix"
            }
          }
        }
      }
    },
    "privacy_class_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "privacy_class",
        "allowed_in_public_objects",
        "requires_redaction",
        "requires_owner",
        "validator_rule_ref"
      ],
      "properties": {
        "privacy_class": {
          "$ref": "#/$defs/privacy_class"
        },
        "allowed_in_public_objects": {
          "type": "boolean"
        },
        "requires_redaction": {
          "type": "boolean"
        },
        "requires_owner": {
          "type": "boolean"
        },
        "validator_rule_ref": {
          "$ref": "#/$defs/ref_prefix"
        }
      }
    },
    "correction_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_name",
        "required",
        "field_ref"
      ],
      "properties": {
        "field_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "required": {
          "type": "boolean"
        },
        "field_ref": {
          "$ref": "#/$defs/ref_prefix"
        }
      }
    },
    "reason_code_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason_code",
        "reason_family",
        "retryability",
        "correction_fields",
        "dependency_name",
        "policy_ref",
        "audit_ref",
        "unsupported_version",
        "documented",
        "rust_first_enum_source"
      ],
      "properties": {
        "reason_code": {
          "$ref": "#/$defs/reason_code"
        },
        "reason_family": {
          "enum": [
            "schema",
            "validation",
            "policy",
            "dependency",
            "unsupported_version"
          ]
        },
        "retryability": {
          "enum": [
            "not_retryable",
            "safe_retry",
            "retry_after",
            "operator_review"
          ]
        },
        "correction_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/correction_field"
          }
        },
        "dependency_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "policy_ref": {
          "$ref": "#/$defs/ref_prefix"
        },
        "audit_ref": {
          "$ref": "#/$defs/ref_prefix"
        },
        "unsupported_version": {
          "type": "boolean"
        },
        "documented": {
          "const": true
        },
        "rust_first_enum_source": {
          "const": true
        }
      }
    },
    "phase3_contract_modules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_tenant_modules",
        "command_api_error_modules",
        "event_audit_modules",
        "manifest_registry_modules",
        "queue_lease_credential_key_modules"
      ],
      "properties": {
        "identity_tenant_modules": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        },
        "command_api_error_modules": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        },
        "event_audit_modules": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        },
        "manifest_registry_modules": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        },
        "queue_lease_credential_key_modules": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        }
      }
    },
    "phase3_contract_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_name",
        "module_family",
        "schema_version",
        "owning_service_family",
        "downstream_consumers",
        "source_of_truth",
        "rust_projection_non_authoritative",
        "runtime_authority",
        "privacy_class",
        "strict_unknown_field_rejection",
        "raw_secret_values_allowed",
        "private_key_material_allowed",
        "tenant_actor_refs_required",
        "append_only_record",
        "reason_code_required",
        "correction_shape_required",
        "privacy_class_required",
        "typed_secret_refs_required",
        "untyped_capability_blobs_allowed",
        "required_refs",
        "required_fields",
        "validation_rules"
      ],
      "properties": {
        "module_name": {
          "enum": [
            "identity",
            "tenant",
            "command",
            "api_error",
            "event",
            "audit",
            "workload_manifest",
            "resource_manifest",
            "registry_metadata",
            "queue_and_lease",
            "credential_key_metadata"
          ]
        },
        "module_family": {
          "enum": [
            "identity_tenant",
            "command_api_error",
            "event_audit",
            "manifest_registry",
            "queue_lease_credential_key"
          ]
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "owning_service_family": {
          "$ref": "#/$defs/non_empty_string"
        },
        "downstream_consumers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "source_of_truth": {
          "const": "json_schema"
        },
        "rust_projection_non_authoritative": {
          "const": true
        },
        "runtime_authority": {
          "const": "owning_service"
        },
        "privacy_class": {
          "$ref": "#/$defs/privacy_class"
        },
        "strict_unknown_field_rejection": {
          "const": true
        },
        "raw_secret_values_allowed": {
          "const": false
        },
        "private_key_material_allowed": {
          "const": false
        },
        "tenant_actor_refs_required": {
          "type": "boolean"
        },
        "append_only_record": {
          "type": "boolean"
        },
        "reason_code_required": {
          "type": "boolean"
        },
        "correction_shape_required": {
          "type": "boolean"
        },
        "privacy_class_required": {
          "type": "boolean"
        },
        "typed_secret_refs_required": {
          "type": "boolean"
        },
        "untyped_capability_blobs_allowed": {
          "const": false
        },
        "required_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "validation_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/phase3_contract_rule"
          }
        }
      }
    },
    "phase3_contract_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "reason_code",
        "correction_fields",
        "enforcement"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reason_code": {
          "$ref": "#/$defs/reason_code"
        },
        "correction_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "enforcement": {
          "enum": [
            "require",
            "reject",
            "preserve_append_only",
            "require_typed_ref"
          ]
        }
      }
    },
    "phase4_generation_toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toolchain_decision",
        "generation_commands",
        "source_hash_inputs",
        "rust_outputs",
        "docs_projection",
        "typescript_web_projection",
        "protobuf_projection",
        "reproducibility"
      ],
      "properties": {
        "toolchain_decision": {
          "$ref": "#/$defs/phase4_toolchain_decision"
        },
        "generation_commands": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/phase4_generation_command"
          }
        },
        "source_hash_inputs": {
          "type": "array",
          "minItems": 3,
          "items": {
            "enum": [
              "packages/schemas/overrid_contracts/v0/shared_schema_package.schema.json",
              "packages/schemas/overrid_contracts/codegen_manifest.json",
              "docs/build_plan/sub_build_plan_007_shared_schema_package.md",
              "docs/overrid_tech_stack_choice.md"
            ]
          }
        },
        "rust_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/phase4_projection_output"
          }
        },
        "docs_projection": {
          "$ref": "#/$defs/phase4_docs_projection"
        },
        "typescript_web_projection": {
          "$ref": "#/$defs/phase4_typescript_projection"
        },
        "protobuf_projection": {
          "$ref": "#/$defs/phase4_protobuf_projection"
        },
        "reproducibility": {
          "$ref": "#/$defs/phase4_reproducibility"
        }
      }
    },
    "phase4_toolchain_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toolchain_name",
        "canonical_source",
        "source_of_truth",
        "rust_first",
        "typescript_second",
        "generated_outputs_non_authoritative",
        "hand_edited_generated_files_allowed",
        "protobuf_public_authority_allowed"
      ],
      "properties": {
        "toolchain_name": {
          "const": "rust-json-schema-projection-v0"
        },
        "canonical_source": {
          "const": "packages/schemas/overrid_contracts/v0/shared_schema_package.schema.json"
        },
        "source_of_truth": {
          "const": "json_schema"
        },
        "rust_first": {
          "const": true
        },
        "typescript_second": {
          "const": true
        },
        "generated_outputs_non_authoritative": {
          "const": true
        },
        "hand_edited_generated_files_allowed": {
          "const": false
        },
        "protobuf_public_authority_allowed": {
          "const": false
        }
      }
    },
    "phase4_generation_command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_name",
        "command",
        "deterministic",
        "source_inputs",
        "output_paths",
        "dry_run_reason_code"
      ],
      "properties": {
        "command_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "command": {
          "$ref": "#/$defs/non_empty_string"
        },
        "deterministic": {
          "const": true
        },
        "source_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "output_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "dry_run_reason_code": {
          "$ref": "#/$defs/reason_code"
        }
      }
    },
    "phase4_projection_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "path",
        "source_schema",
        "non_authoritative",
        "validator_entrypoint",
        "contains_redaction_metadata",
        "contains_reason_code_metadata"
      ],
      "properties": {
        "target": {
          "enum": [
            "rust",
            "docs",
            "typescript_web",
            "protobuf_internal"
          ]
        },
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_schema": {
          "const": "packages/schemas/overrid_contracts/v0/shared_schema_package.schema.json"
        },
        "non_authoritative": {
          "const": true
        },
        "validator_entrypoint": {
          "$ref": "#/$defs/non_empty_string"
        },
        "contains_redaction_metadata": {
          "type": "boolean"
        },
        "contains_reason_code_metadata": {
          "type": "boolean"
        }
      }
    },
    "phase4_docs_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_path",
        "source_to_doc_trace",
        "required_sections",
        "requires_descriptions",
        "requires_examples",
        "requires_privacy_class",
        "requires_reason_code_links"
      ],
      "properties": {
        "output_path": {
          "const": "packages/schemas/overrid_contracts/generated/docs/shared_schema_package_phase4_reference.md"
        },
        "source_to_doc_trace": {
          "const": true
        },
        "required_sections": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "requires_descriptions": {
          "const": true
        },
        "requires_examples": {
          "const": true
        },
        "requires_privacy_class": {
          "const": true
        },
        "requires_reason_code_links": {
          "const": true
        }
      }
    },
    "phase4_typescript_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source_schema",
        "output_root",
        "blocked_until",
        "browser_safe_redaction",
        "source_of_truth_allowed"
      ],
      "properties": {
        "status": {
          "const": "blocked_until_rust_and_fixtures_stable"
        },
        "source_schema": {
          "const": "packages/schemas/overrid_contracts/v0/shared_schema_package.schema.json"
        },
        "output_root": {
          "const": "packages/schemas/admin_ui/generated"
        },
        "blocked_until": {
          "type": "array",
          "minItems": 4,
          "items": {
            "enum": [
              "rust_projection_validated",
              "golden_fixtures_stable",
              "docs_trace_validated",
              "compatibility_checks_stable"
            ]
          }
        },
        "browser_safe_redaction": {
          "const": true
        },
        "source_of_truth_allowed": {
          "const": false
        }
      }
    },
    "phase4_protobuf_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "scope",
        "output_root",
        "json_schema_source_required",
        "public_object_definition_allowed",
        "public_payload_families_blocked"
      ],
      "properties": {
        "status": {
          "const": "internal_only_when_owning_sds_approves"
        },
        "scope": {
          "const": "compact_internal_service_rpc_event_contracts"
        },
        "output_root": {
          "const": "packages/schemas/overrid_contracts/protobuf/internal"
        },
        "json_schema_source_required": {
          "const": true
        },
        "public_object_definition_allowed": {
          "const": false
        },
        "public_payload_families_blocked": {
          "type": "array",
          "minItems": 5,
          "items": {
            "enum": [
              "command_payloads",
              "signed_payloads",
              "manifests",
              "policy_declarations",
              "fixtures",
              "docs_examples",
              "api_errors",
              "reason_codes",
              "audit_records"
            ]
          }
        }
      }
    },
    "phase4_reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deterministic",
        "source_to_output_trace_required",
