{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.overrid.local/overrid_contracts/v0/shared_schema_package.schema.json",
  "title": "Shared Schema Package Phase 2 And Phase 3 Contracts",
  "description": "Canonical JSON Schema source for SUB BUILD PLAN #7 Phase 2 package layout/common primitives and Phase 3 Phase 0/1 contract modules.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_family",
    "schema_version",
    "layout",
    "identifier_primitives",
    "lifecycle_primitives",
    "privacy_classes",
    "reason_code_registry"
  ],
  "properties": {
    "schema_family": {
      "const": "shared-schema-package"
    },
    "schema_version": {
      "$ref": "#/$defs/schema_version"
    },
    "layout": {
      "$ref": "#/$defs/source_layout"
    },
    "identifier_primitives": {
      "type": "array",
      "minItems": 19,
      "items": {
        "$ref": "#/$defs/typed_ref_primitive"
      }
    },
    "lifecycle_primitives": {
      "$ref": "#/$defs/lifecycle_primitives"
    },
    "privacy_classes": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/privacy_class_rule"
      }
    },
    "reason_code_registry": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/reason_code_entry"
      }
    },
    "phase3_contract_modules": {
      "$ref": "#/$defs/phase3_contract_modules"
    }
  },
  "$defs": {
    "schema_version": {
      "const": "shared-schema-package.v0.1"
    },
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "ref_prefix": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:"
    },
    "reason_code": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"
    },
    "privacy_class": {
      "enum": [
        "public",
        "tenant_private",
        "regulated",
        "encrypted_private",
        "user_content",
        "system_service_only",
        "redacted_diagnostic"
      ]
    },
    "source_layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved_source_roots",
        "generated_output_roots",
        "fixture_roots",
        "compatibility_report_roots",
        "internal_binary_projection_roots",
        "generated_in_source_directories"
      ],
      "properties": {
        "approved_source_roots": {
          "type": "array",
          "minItems": 4,
          "items": {
            "enum": [
              "packages/schemas/README.md",
              "packages/schemas/overrid_contracts/v0",
              "packages/schemas/overrid_contracts/codegen_manifest.json",
              "packages/schemas/overrid_contracts/README.md"
            ]
          }
        },
        "generated_output_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "packages/schemas/overrid_contracts/src/lib.rs",
              "packages/schemas/admin_ui/generated"
            ]
          }
        },
        "fixture_roots": {
          "type": "array",
          "minItems": 2,
          "items": {
            "enum": [
              "packages/schemas/overrid_contracts/fixtures/valid",
              "packages/schemas/overrid_contracts/fixtures/invalid"
            ]
          }
        },
        "compatibility_report_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "packages/schemas/overrid_contracts/compatibility",
              "docs/specs/generated"
            ]
          }
        },
        "internal_binary_projection_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "packages/schemas/overrid_contracts/protobuf/internal"
            ]
          }
        },
        "generated_in_source_directories": {
          "const": false
        }
      }
    },
    "typed_ref_primitive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primitive_name",
        "object_family",
        "ref_prefix",
        "privacy_class",
        "public_object_required",
        "unstructured_string_allowed",
        "versioned_when_external",
        "examples"
      ],
      "properties": {
        "primitive_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "object_family": {
          "enum": [
            "person",
            "organization",
            "tenant",
            "node",
            "app",
            "native_service",
            "service_account",
            "system_service",
            "central_ai_actor",
            "overasset",
            "namespace",
            "route",
            "package",
            "workload",
            "queue",
            "lease",
            "receipt",
            "evidence",
            "secret_reference"
          ]
        },
        "ref_prefix": {
          "$ref": "#/$defs/ref_prefix"
        },
        "privacy_class": {
          "$ref": "#/$defs/privacy_class"
        },
        "public_object_required": {
          "type": "boolean"
        },
        "unstructured_string_allowed": {
          "const": false
        },
        "versioned_when_external": {
          "type": "boolean"
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "lifecycle_primitives": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "logical_sequence",
        "schema_version",
        "command_id",
        "trace_id",
        "idempotency_key",
        "request_hash",
        "payload_hash",
        "compatibility_window",
        "deprecation_metadata"
      ],
      "properties": {
        "timestamp": {
          "$ref": "#/$defs/non_empty_string"
        },
        "logical_sequence": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "command_id": {
          "$ref": "#/$defs/ref_prefix"
        },
        "trace_id": {
          "const": "trace_"
        },
        "idempotency_key": {
          "const": "idem_"
        },
        "request_hash": {
          "const": "hash_"
        },
        "payload_hash": {
          "const": "hash_"
        },
        "compatibility_window": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "current_major",
            "previous_major_supported"
          ],
          "properties": {
            "current_major": {
              "type": "integer",
              "minimum": 0
            },
            "previous_major_supported": {
              "const": true
            }
          }
        },
        "deprecation_metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "deprecated_since",
            "retirement_after",
            "migration_plan_ref"
          ],
          "properties": {
            "deprecated_since": {
              "$ref": "#/$defs/non_empty_string"
            },
            "retirement_after": {
              "$ref": "#/$defs/non_empty_string"
            },
            "migration_plan_ref": {
              "$ref": "#/$defs/ref_prefix"
            }
          }
        }
      }
    },
    "privacy_class_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "privacy_class",
        "allowed_in_public_objects",
        "requires_redaction",
        "requires_owner",
        "validator_rule_ref"
      ],
      "properties": {
        "privacy_class": {
          "$ref": "#/$defs/privacy_class"
        },
        "allowed_in_public_objects": {
          "type": "boolean"
        },
        "requires_redaction": {
          "type": "boolean"
        },
        "requires_owner": {
          "type": "boolean"
        },
        "validator_rule_ref": {
          "$ref": "#/$defs/ref_prefix"
        }
      }
    },
    "correction_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_name",
        "required",
        "field_ref"
      ],
      "properties": {
        "field_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "required": {
          "type": "boolean"
        },
        "field_ref": {
          "$ref": "#/$defs/ref_prefix"
        }
      }
    },
    "reason_code_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason_code",
        "reason_family",
        "retryability",
        "correction_fields",
        "dependency_name",
        "policy_ref",
        "audit_ref",
        "unsupported_version",
        "documented",
        "rust_first_enum_source"
      ],
      "properties": {
        "reason_code": {
          "$ref": "#/$defs/reason_code"
        },
        "reason_family": {
          "enum": [
            "schema",
            "validation",
            "policy",
            "dependency",
            "unsupported_version"
          ]
        },
        "retryability": {
          "enum": [
            "not_retryable",
            "safe_retry",
            "retry_after",
            "operator_review"
          ]
        },
        "correction_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/correction_field"
          }
        },
        "dependency_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "policy_ref": {
          "$ref": "#/$defs/ref_prefix"
        },
        "audit_ref": {
          "$ref": "#/$defs/ref_prefix"
        },
        "unsupported_version": {
          "type": "boolean"
        },
        "documented": {
          "const": true
        },
        "rust_first_enum_source": {
          "const": true
        }
      }
    },
    "phase3_contract_modules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_tenant_modules",
        "command_api_error_modules",
        "event_audit_modules",
        "manifest_registry_modules",
        "queue_lease_credential_key_modules"
      ],
      "properties": {
        "identity_tenant_modules": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        },
        "command_api_error_modules": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        },
        "event_audit_modules": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        },
        "manifest_registry_modules": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        },
        "queue_lease_credential_key_modules": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/phase3_contract_module"
          }
        }
      }
    },
    "phase3_contract_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_name",
        "module_family",
        "schema_version",
        "owning_service_family",
        "downstream_consumers",
        "source_of_truth",
        "rust_projection_non_authoritative",
        "runtime_authority",
        "privacy_class",
        "strict_unknown_field_rejection",
        "raw_secret_values_allowed",
        "private_key_material_allowed",
        "tenant_actor_refs_required",
        "append_only_record",
        "reason_code_required",
        "correction_shape_required",
        "privacy_class_required",
        "typed_secret_refs_required",
        "untyped_capability_blobs_allowed",
        "required_refs",
        "required_fields",
        "validation_rules"
      ],
      "properties": {
        "module_name": {
          "enum": [
            "identity",
            "tenant",
            "command",
            "api_error",
            "event",
            "audit",
            "workload_manifest",
            "resource_manifest",
            "registry_metadata",
            "queue_and_lease",
            "credential_key_metadata"
          ]
        },
        "module_family": {
          "enum": [
            "identity_tenant",
            "command_api_error",
            "event_audit",
            "manifest_registry",
            "queue_lease_credential_key"
          ]
        },
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "owning_service_family": {
          "$ref": "#/$defs/non_empty_string"
        },
        "downstream_consumers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "source_of_truth": {
          "const": "json_schema"
        },
        "rust_projection_non_authoritative": {
          "const": true
        },
        "runtime_authority": {
          "const": "owning_service"
        },
        "privacy_class": {
          "$ref": "#/$defs/privacy_class"
        },
        "strict_unknown_field_rejection": {
          "const": true
        },
        "raw_secret_values_allowed": {
          "const": false
        },
        "private_key_material_allowed": {
          "const": false
        },
        "tenant_actor_refs_required": {
          "type": "boolean"
        },
        "append_only_record": {
          "type": "boolean"
        },
        "reason_code_required": {
          "type": "boolean"
        },
        "correction_shape_required": {
          "type": "boolean"
        },
        "privacy_class_required": {
          "type": "boolean"
        },
        "typed_secret_refs_required": {
          "type": "boolean"
        },
        "untyped_capability_blobs_allowed": {
          "const": false
        },
        "required_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "validation_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/phase3_contract_rule"
          }
        }
      }
    },
    "phase3_contract_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "reason_code",
        "correction_fields",
        "enforcement"
      ],
      "properties": {
        "rule_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reason_code": {
          "$ref": "#/$defs/reason_code"
        },
        "correction_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "enforcement": {
          "enum": [
            "require",
            "reject",
            "preserve_append_only",
            "require_typed_ref"
          ]
        }
      }
    }
  }
}
